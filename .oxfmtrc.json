{
   "$schema": "./node_modules/oxfmt/configuration_schema.json",
   "printWidth": 100,
   "semi": false,
   "singleQuote": true,
   "tabWidth": 3,
   "trailingComma": "es5",
   "useTabs": false,
   "ignorePatterns": [".vscode/**", "node_modules/**", "dist/**", "target/**"],
   "sortPackageJson": {
      "sortScripts": true
   }
}
